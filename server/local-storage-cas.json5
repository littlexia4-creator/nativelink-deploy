// NativeLink CAS + AC Store
// Data stored in /root/.cache/nativelink/ (bind-mounted from host).
// CAS uses LZ4 compression. Adjust max_bytes to fit your disk.
{
  stores: [
    {
      name: "CAS_MAIN_STORE",
      compression: {
        compression_algorithm: {
          lz4: {},
        },
        backend: {
          filesystem: {
            content_path: "/root/.cache/nativelink/content_path-cas",
            temp_path: "/root/.cache/nativelink/tmp_path-cas",
            eviction_policy: {
              // 500GB — adjust based on available disk.
              max_bytes: 500000000000,
            },
          },
        },
      },
    },
    {
      name: "AC_MAIN_STORE",
      filesystem: {
        content_path: "/root/.cache/nativelink/content_path-ac",
        temp_path: "/root/.cache/nativelink/tmp_path-ac",
        eviction_policy: {
          // 10GB.
          max_bytes: 10000000000,
        },
      },
    },
  ],
  servers: [
    {
      listener: {
        http: {
          socket_address: "0.0.0.0:50051",
          // 128MB — required for large Chromium toolchain uploads.
          max_decoding_message_size: 134217728,
        },
      },
      services: {
        cas: [
          {
            cas_store: "CAS_MAIN_STORE",
          },
        ],
        ac: [
          {
            ac_store: "AC_MAIN_STORE",
          },
        ],
        capabilities: [],
        bytestream: [
          {
            "instance_name": "",
            "cas_store": "CAS_MAIN_STORE"
          }
        ],
        fetch: [],
        push: [],
      },
    },
  ],
}
